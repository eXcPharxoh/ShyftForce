generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())

  // Branding
  logoUrl  String?
  timezone String  @default("America/New_York")
  industry String? // restaurant | retail | healthcare | field_service | office | fitness | other
  isDemo   Boolean @default(false)

  // Default locale for new members (members can override on their own profile)
  defaultLocale String @default("en") // "en" | "es" | "fr"

  // BYO-Twilio credentials. If set, SMS is sent on this org's account; if null,
  // we fall back to the platform-wide Twilio config (subject to per-message
  // billing back to the customer).
  twilioAccountSid String?
  twilioAuthToken  String?
  twilioFromNumber String?

  // Billing (Stripe)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 String    @default("trial") // trial | starter | pro | enterprise
  trialEndsAt          DateTime?
  subscriptionStatus   String? // active | past_due | canceled | incomplete

  // Payroll integration (Finch)
  finchAccessToken String? // encrypted in production
  finchProviderId  String? // e.g. "adp_workforce_now", "gusto", "paychex"
  finchCompanyId   String? // Finch's internal company id
  finchConnectedAt DateTime?

  locations               Location[]
  members                 Member[]
  payPeriods              PayPeriod[]
  surveys                 Survey[]
  documents               Document[]
  billboardPosts          BillboardPost[]
  dayNotes                DayNote[]
  hrReminders             HRReminder[]
  complianceSettings      ComplianceSettings?
  ptoPolicies             PtoPolicy[]
  invitations             Invitation[]
  auditLogs               AuditLog[]
  predictabilityPayEvents PredictabilityPayEvent[]
  posConnections          PosConnection[]
  ewaSettings             EwaSettings?
  ewaWithdrawals          EwaWithdrawal[]
  demandForecasts         DemandForecast[]
  demandContexts          DemandContext[]
  networkShiftOffers      NetworkShiftOffer[]
  incidentReports         IncidentReport[]
  checkpointPosts         CheckpointPost[]
  clientAccounts          ClientAccount[]
  tipPools                TipPool[]
  scheduleTemplates       ScheduleTemplate[]
  webhookSubscriptions    WebhookSubscription[]
  webhookDeliveries       WebhookDelivery[]
  smsMessages             SmsMessage[]
  apiKeys                 ApiKey[]
  kioskDevices            KioskDevice[]
  slackConnection         SlackConnection?
  customRoles             CustomRole[]
  courses                 Course[]
  reviewCycles            ReviewCycle[]
  permits                 Permit[]
  eightySixItems          EightySixItem[]
  checklistTemplates      ChecklistTemplate[]
  checklistInstances      ChecklistInstance[]
  cashDrawerSessions      CashDrawerSession[]
  laborTargets            LaborTarget[]
  patientRatioRules       PatientRatioRule[]
  shiftDifferentials      ShiftDifferential[]
  onCallShifts            OnCallShift[]
  vehicles                Vehicle[]
  jobCloseouts            JobCloseout[]
  departments             Department[]
  posLanes                PosLane[]
  shrinkEvents            ShrinkEvent[]
  vmTasks                 VmTask[]
  lossPreventionEvents    LossPreventionEvent[]
  hotDesks                HotDesk[]
  meetingRooms            MeetingRoom[]
  visitors                Visitor[]
  fitnessClasses          FitnessClass[]
  ptSessions              PtSession[]
}

model ComplianceSettings {
  id                          String  @id @default(uuid())
  organizationId              String  @unique
  maxWeeklyHours              Float   @default(40)
  maxDailyHours               Float   @default(12)
  minRestGapHours             Float   @default(8)
  mealBreakRequiredAfterHours Float   @default(5)
  restBreakRequiredAfterHours Float   @default(4) // CA-style 10-min paid every 4h
  maxConsecutiveDays          Int     @default(6)
  predictiveSchedulingDays    Int     @default(0) // Fair Workweek lead time (days)
  jurisdiction                String  @default("default") // see lib/compliance/jurisdictions.ts
  industry                    String  @default("default") // retail | food | hospitality | healthcare | other
  predictabilityPayEnabled    Boolean @default(false)
  minorAgeThreshold           Int     @default(18)
  minorMaxDailyHours          Float   @default(8)
  minorMaxWeeklyHours         Float   @default(40)
  minorEarliestStartHour      Int     @default(7)
  minorLatestEndHour          Int     @default(22)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model PredictabilityPayEvent {
  id              String    @id @default(uuid())
  organizationId  String
  shiftId         String
  memberId        String
  changeType      String // added | moved | canceled | shortened
  occurredAt      DateTime  @default(now())
  shiftStartsAt   DateTime
  noticeHours     Float // hours of notice given before shift
  hoursOwed       Float
  hourlyRate      Float
  amountOwedCents Int
  reason          String?
  resolvedAt      DateTime?
  resolvedById    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shift        Shift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([organizationId, occurredAt])
  @@index([memberId, resolvedAt])
}

model PosConnection {
  id             String    @id @default(uuid())
  organizationId String
  locationId     String?
  provider       String // toast | square | clover | manual
  status         String    @default("connected") // connected | error | disconnected
  accessToken    String? // encrypted in production
  refreshToken   String?
  externalId     String? // POS-side restaurant/location id
  lastSyncAt     DateTime?
  syncError      String?
  createdAt      DateTime  @default(now())

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?            @relation(fields: [locationId], references: [id])
  snapshots    PosRevenueSnapshot[]

  @@index([organizationId, status])
}

model PosRevenueSnapshot {
  id               String   @id @default(uuid())
  connectionId     String
  locationId       String
  intervalStart    DateTime
  intervalEnd      DateTime
  grossSalesCents  Int
  netSalesCents    Int?
  transactionCount Int      @default(0)
  source           String   @default("api") // api | manual
  createdAt        DateTime @default(now())

  connection PosConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  location   Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, intervalStart, intervalEnd])
  @@index([locationId, intervalStart])
}

model EwaSettings {
  id                    String   @id @default(uuid())
  organizationId        String   @unique
  enabled               Boolean  @default(false)
  earnedRatePercent     Int      @default(50) // % of earned-but-unpaid wages accessible
  feeCentsPerWithdrawal Int      @default(199) // $1.99 default
  minWithdrawalCents    Int      @default(2000) // $20 minimum
  maxPerPayPeriodCents  Int      @default(50000) // $500 max per pay period
  providerName          String   @default("internal_ledger") // internal_ledger | branch | tapcheck | dailypay | stripe_treasury
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model IncidentReport {
  id              String    @id @default(uuid())
  organizationId  String
  locationId      String?
  reportedById    String // memberId
  shiftId         String?
  occurredAt      DateTime
  category        String // theft | trespass | medical | altercation | property_damage | policy_violation | safety | other
  severity        String    @default("low") // low | medium | high | critical
  title           String
  body            String
  witnessNames    String?
  photoData       String? // base64 small image or external URL
  policeReportNo  String?
  status          String    @default("open") // open | reviewing | resolved | escalated
  reviewedById    String?
  reviewedAt      DateTime?
  resolutionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id])
  reportedBy   Member       @relation("IncidentReporter", fields: [reportedById], references: [id], onDelete: Cascade)
  reviewedBy   Member?      @relation("IncidentReviewer", fields: [reviewedById], references: [id])
  shift        Shift?       @relation(fields: [shiftId], references: [id])

  @@index([organizationId, status, occurredAt])
  @@index([locationId, occurredAt])
}

model CheckpointPost {
  id               String   @id @default(uuid())
  organizationId   String
  locationId       String
  name             String
  qrToken          String   @unique
  latitude         Float?
  longitude        Float?
  expectedSequence Int      @default(0) // order in patrol; 0 = unordered
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  scans        CheckpointScan[]

  @@index([locationId, active])
}

model CheckpointScan {
  id             String   @id @default(uuid())
  postId         String
  memberId       String
  shiftId        String?
  at             DateTime @default(now())
  latitude       Float?
  longitude      Float?
  withinGeofence Boolean?
  notes          String?

  post   CheckpointPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  member Member         @relation("CheckpointScanner", fields: [memberId], references: [id], onDelete: Cascade)
  shift  Shift?         @relation(fields: [shiftId], references: [id])

  @@index([postId, at])
  @@index([memberId, at])
  @@index([shiftId])
}

model ClientAccount {
  id                 String   @id @default(uuid())
  organizationId     String
  name               String
  contactName        String?
  contactEmail       String?
  contactPhone       String?
  billRateCents      Int      @default(3500) // default $35/hr
  overtimeMultiplier Float    @default(1.5)
  invoiceTerms       String   @default("net_30") // net_15 | net_30 | net_60 | due_on_receipt
  active             Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locations    Location[]   @relation("LocationClient")

  @@index([organizationId, active])
}

model TipPool {
  id               String   @id @default(uuid())
  organizationId   String
  locationId       String
  date             DateTime
  totalTipsCents   Int
  distributionRule String   @default("hours") // hours | role_weighted | equal | custom
  notes            String?
  createdById      String?
  status           String   @default("draft") // draft | distributed | finalized
  createdAt        DateTime @default(now())

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location      Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  distributions TipDistribution[]

  @@index([organizationId, date])
  @@index([locationId, date])
}

model TipDistribution {
  id          String @id @default(uuid())
  tipPoolId   String
  memberId    String
  hoursWorked Float
  weight      Float  @default(1.0)
  amountCents Int

  pool   TipPool @relation(fields: [tipPoolId], references: [id], onDelete: Cascade)
  member Member  @relation("TipRecipient", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([tipPoolId, memberId])
  @@index([memberId])
}

model ImpersonationGrant {
  id           String    @id @default(uuid())
  adminUserId  String
  targetUserId String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  expiresAt    DateTime
  reason       String?
  ipAddress    String?
  userAgent    String?

  adminUser  User @relation("ImpersonationAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)
  targetUser User @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, endedAt])
  @@index([targetUserId, endedAt])
}

model WorkerProfile {
  id                   String    @id @default(uuid())
  userId               String    @unique
  // Identity (collected once, used everywhere)
  legalFirstName       String?
  legalLastName        String?
  dateOfBirth          DateTime?
  identityVerifiedAt   DateTime?
  identityProvider     String? // stripe_identity | persona | manual
  // Discoverability + profile
  discoverable         Boolean   @default(false)
  bio                  String?
  city                 String?
  stateRegion          String?
  skills               String? // JSON array of strings
  // Cross-employer reputation cache
  totalShiftsCompleted Int       @default(0)
  totalNoShows         Int       @default(0)
  totalEmployers       Int       @default(0)
  reputationScore      Float? // 0-100
  reputationUpdatedAt  DateTime?
  // Cross-employer payment routing (tokenized only — never raw bank data)
  payoutMethodToken    String?
  payoutMethodLast4    String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  networkClaims  NetworkShiftOffer[] @relation("ClaimedByWorker")
  invitedOffers  NetworkShiftOffer[] @relation("InvitedWorker")
  externalShifts Shift[]             @relation("ExternalWorker")

  @@index([discoverable, reputationScore])
}

model NetworkShiftOffer {
  id                   String    @id @default(uuid())
  shiftId              String
  postingOrgId         String
  postedById           String? // memberId of the manager who posted
  invitedWorkerId      String? // null = open to all discoverable workers
  status               String    @default("open") // open | claimed | filled_internally | closed | canceled
  payoutType           String    @default("w2") // w2 | 1099
  payRateOverrideCents Int?
  message              String?
  claimedById          String? // workerProfileId
  claimedAt            DateTime?
  closedAt             DateTime?
  createdAt            DateTime  @default(now())

  shift         Shift          @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  postingOrg    Organization   @relation(fields: [postingOrgId], references: [id], onDelete: Cascade)
  invitedWorker WorkerProfile? @relation("InvitedWorker", fields: [invitedWorkerId], references: [id])
  claimedBy     WorkerProfile? @relation("ClaimedByWorker", fields: [claimedById], references: [id])

  @@index([postingOrgId, status])
  @@index([invitedWorkerId, status])
  @@index([claimedById, status])
  @@index([shiftId])
}

model DemandForecast {
  id                    String   @id @default(uuid())
  organizationId        String
  locationId            String
  slotStart             DateTime
  slotEnd               DateTime
  predictedRevenueCents Int
  predictedHeadcount    Int
  confidence            Float    @default(0.5)
  contextNotes          String?
  generatedAt           DateTime @default(now())
  generatedBy           String   @default("autopilot") // autopilot | claude | manual

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, slotStart])
  @@index([organizationId, slotStart])
}

model DemandContext {
  id                String   @id @default(uuid())
  organizationId    String
  locationId        String?
  startsAt          DateTime
  endsAt            DateTime
  category          String // weather | event | holiday | promotion | manual
  label             String
  expectedImpactPct Float    @default(0) // -100 to +100
  source            String? // manual | openweathermap | claude | ticketmaster
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id])

  @@index([locationId, startsAt])
  @@index([organizationId, startsAt])
}

model EwaWithdrawal {
  id              String    @id @default(uuid())
  memberId        String
  organizationId  String
  amountCents     Int
  feeCentsCharged Int       @default(0)
  status          String    @default("pending") // pending | processing | settled | failed | canceled
  payoutMethod    String? // ach | instant_debit | demo
  requestedAt     DateTime  @default(now())
  settledAt       DateTime?
  externalRef     String? // provider-side id
  failureReason   String?
  payPeriodId     String?

  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payPeriod    PayPeriod?   @relation(fields: [payPeriodId], references: [id])

  @@index([memberId, status])
  @@index([organizationId, requestedAt])
}

model Location {
  id                   String   @id @default(uuid())
  organizationId       String
  name                 String
  weeklyBudget         Float?
  projectedRevenue     Float?
  latitude             Float?
  longitude            Float?
  geofenceRadiusMeters Int      @default(100)
  createdAt            DateTime @default(now())

  clientId           String?
  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members            Member[]
  shifts             Shift[]
  posConnections     PosConnection[]
  posRevenue         PosRevenueSnapshot[]
  demandForecasts    DemandForecast[]
  demandContexts     DemandContext[]
  incidentReports    IncidentReport[]
  checkpointPosts    CheckpointPost[]
  tipPools           TipPool[]
  client             ClientAccount?       @relation("LocationClient", fields: [clientId], references: [id])
  eightySixItems     EightySixItem[]
  checklistTemplates ChecklistTemplate[]
  checklistInstances ChecklistInstance[]
  cashDrawerSessions CashDrawerSession[]
  laborTarget        LaborTarget?
  patientRatioRules  PatientRatioRule[]
  vehicles           Vehicle[]
  onCallShifts       OnCallShift[]
  departments        Department[]
  posLanes           PosLane[]
  shrinkEvents       ShrinkEvent[]
  vmTasks            VmTask[]
  lpEvents           LossPreventionEvent[]
  hotDesks           HotDesk[]
  meetingRooms       MeetingRoom[]
  visitors           Visitor[]
  fitnessClasses     FitnessClass[]
  KioskDevice        KioskDevice[]

  @@index([organizationId])
  @@index([clientId])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  createdAt DateTime @default(now())

  emailVerified       DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // 2FA / TOTP. totpSecret is base32-encoded; only populated after the user
  // completes setup. recoveryCodes is a JSON array of bcrypt-hashed one-shot
  // codes (shown once on enroll so user can stash them).
  totpEnabled   Boolean @default(false)
  totpSecret    String?
  recoveryCodes String? // JSON array of hashed codes

  member                 Member?
  workerProfile          WorkerProfile?
  emailTokens            EmailVerification[]
  passwordResets         PasswordReset[]
  auditLogs              AuditLog[]
  impersonationsGiven    ImpersonationGrant[] @relation("ImpersonationAdmin")
  impersonationsReceived ImpersonationGrant[] @relation("ImpersonationTarget")
  pushSubscriptions      PushSubscription[]
  oauthIdentities        OAuthIdentity[]
}

// ============================================================================
// Web Push subscriptions. One row per (user, browser/device). Service worker
// pushes land here; we delete on 410 Gone (subscription expired).
// ============================================================================
model PushSubscription {
  id         String    @id @default(uuid())
  userId     String
  endpoint   String    @unique
  p256dh     String // public key from PushSubscription.getKey('p256dh')
  auth       String // public key from PushSubscription.getKey('auth')
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================================
// Scoped API keys for the public REST API. Admins create keys with specific
// scopes (read:shifts, write:shifts, etc.). We store a bcrypt hash — the raw
// key is shown ONCE on creation.
// ============================================================================
model ApiKey {
  id             String    @id @default(uuid())
  organizationId String
  name           String // human-friendly label, e.g. "Zapier prod"
  prefix         String // first 12 chars of the key (e.g. "sfk_live_xy"); shown in lists
  keyHash        String // bcrypt hash of the full key
  scopes         String // JSON string array, e.g. ["read:shifts","write:shifts"]
  createdById    String?
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, revokedAt])
  @@index([prefix])
}

// ============================================================================
// Kiosk sessions. Each location can have one or more shared tablets at a
// clock-in station. Once paired, the device holds a long-lived kiosk token;
// employees clock in via their org-unique PIN (4-6 digits).
// ============================================================================
model KioskDevice {
  id             String    @id @default(uuid())
  organizationId String
  locationId     String
  name           String // e.g. "Front desk tablet"
  token          String    @unique // long-lived bearer; rotatable
  pairedAt       DateTime  @default(now())
  lastSeenAt     DateTime?
  revokedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([organizationId, locationId])
}

// ============================================================================
// Slack workspace connection per org. OAuth bot token + per-event channel
// routing. Set the channel once, we drop notifications there.
// ============================================================================
model SlackConnection {
  id                    String   @id @default(uuid())
  organizationId        String   @unique
  teamId                String // Slack workspace ID
  teamName              String
  accessToken           String // bot token: xoxb-…
  defaultChannel        String? // channel ID for fallback
  installedById         String? // userId who completed OAuth
  installedAt           DateTime @default(now())
  // Granular routing
  channelForApprovals   String?
  channelForShiftOffers String?
  channelForIncidents   String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model EmailVerification {
  id         String    @id @default(uuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model PasswordReset {
  id         String    @id @default(uuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Invitation {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  role           String    @default("EMPLOYEE") // ADMIN | MANAGER | EMPLOYEE
  token          String    @unique
  invitedById    String?
  position       String?
  locationId     String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([organizationId, email])
}

model PtoPolicy {
  id             String  @id @default(uuid())
  organizationId String
  category       String // "vacation" | "sick" | "personal" | "bereavement" | "unpaid"
  name           String
  annualHours    Float   @default(0) // 0 = not tracked / unlimited
  accrualMethod  String  @default("annual_lump_sum") // annual_lump_sum | per_pay_period | per_hour_worked | unlimited
  hoursPerDay    Float   @default(8) // used to convert PTO days → hours when reviewing
  maxBalance     Float?
  allowNegative  Boolean @default(false)
  active         Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  balances     PtoBalance[]

  @@unique([organizationId, category])
}

model PtoBalance {
  id              String    @id @default(uuid())
  memberId        String
  policyId        String
  hoursAccrued    Float     @default(0) // total ever accrued (lifetime)
  hoursUsed       Float     @default(0) // total ever used (lifetime)
  lastAccrualAt   DateTime? // last time we ran accrual logic for this member
  lastAccrualYear Int? // year of last lump-sum accrual (for annual reset detection)

  member Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  policy PtoPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([memberId, policyId])
  @@index([memberId])
}

model RecurringShift {
  id             String    @id @default(uuid())
  memberId       String
  locationId     String
  dayOfWeek      Int // 0 = Sun, 1 = Mon, …, 6 = Sat
  startTime      String // HH:MM
  endTime        String // HH:MM
  position       String?
  effectiveFrom  DateTime  @default(now())
  effectiveUntil DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, active])
  @@index([locationId, dayOfWeek])
}

model AvailabilityRule {
  id        String    @id @default(uuid())
  memberId  String
  type      String // "recurring_unavailable" | "one_off_unavailable"
  dayOfWeek Int? // 0-6, required for recurring
  startTime String? // HH:MM, null = whole day
  endTime   String?
  date      DateTime? // required for one-off
  notes     String?
  createdAt DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model ShiftSwapRequest {
  id            String    @id @default(uuid())
  shiftId       String // shift the requester wants to give away
  requesterId   String // member offering the shift
  targetId      String // member they want to swap with
  targetShiftId String? // optional shift to swap into (mutual swap if set)
  message       String?
  status        String    @default("pending") // pending | accepted_by_target | rejected_by_target | approved | rejected | canceled
  decidedAt     DateTime?
  decidedById   String?
  createdAt     DateTime  @default(now())

  shift     Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  requester Member @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target    Member @relation("SwapTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([shiftId])
  @@index([targetId, status])
  @@index([requesterId, status])
}

model MemberCertification {
  id        String    @id @default(uuid())
  memberId  String
  name      String // "Food Handler", "First Aid", "Firearm Permit", "OSHA-30"
  issuedOn  DateTime?
  expiresOn DateTime?
  number    String? // license/cert number
  fileUrl   String? // optional file ref
  notes     String?
  createdAt DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([expiresOn])
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  actorId        String? // user id; null = system
  action         String // e.g. "shift.create", "timesheet.approve", "billing.upgrade"
  entityType     String? // e.g. "Shift", "Member"
  entityId       String?
  metadata       String? // JSON string for diff/payload
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorId])
  @@index([entityType, entityId])
}

// SQLite has no enums — Role is a string: "ADMIN" | "MANAGER" | "EMPLOYEE"
model Member {
  id             String    @id @default(uuid())
  userId         String    @unique
  organizationId String
  locationId     String?
  role           String    @default("EMPLOYEE")
  position       String?
  hourlyRate     Float?
  hireDate       DateTime  @default(now())
  birthday       DateTime?
  status         String    @default("active")

  // Profile additions
  phone                 String?
  emergencyContactName  String?
  emergencyContactPhone String?
  notes                 String? // manager notes about this member
  externalEmployeeId    String? // ID from payroll/HRIS provider (e.g. Finch)
  payrollProvider       String? // "adp_workforce_now" | "gusto" | "paychex" | etc.

  // SMS / notification preferences
  smsOptIn               Boolean @default(true) // master switch
  smsOptInShiftOffer     Boolean @default(true)
  smsOptInScheduleChange Boolean @default(true)
  smsOptInTimeOff        Boolean @default(true)
  smsOptInAlerts         Boolean @default(true)
  smsQuietStartHour      Int? // 0-23, no SMS during quiet hours
  smsQuietEndHour        Int?

  // iCal feed token (rotates on demand). Each member has their own URL they
  // can subscribe to in Apple/Google/Outlook calendar.
  calendarToken String? @unique @default(cuid())

  // Locale override for this user; if null, falls back to org default
  locale String? // "en" | "es" | "fr"

  // 4-6 digit numeric PIN used at shared kiosk devices to clock in. Stored
  // as a bcrypt hash so a DB read doesn't leak punch-in credentials.
  kioskPinHash String?

  // FIELD SERVICE: skill tier (1 = apprentice, 5 = master). Used by the
  // job-complexity matcher so a Level-1 tech doesn't get auto-offered a
  // Level-5 job they can't do. Null = unranked / not applicable.
  skillTier Int?

  certifications    MemberCertification[]
  ptoBalances       PtoBalance[]
  recurringShifts   RecurringShift[]
  availabilityRules AvailabilityRule[]
  swapsAsRequester  ShiftSwapRequest[]    @relation("SwapRequester")
  swapsAsTarget     ShiftSwapRequest[]    @relation("SwapTarget")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id])

  shifts                  Shift[]
  timeOffRequests         TimeOffRequest[]
  expenseRequests         ExpenseRequest[]
  timesheetEntries        TimesheetEntry[]
  attendanceLogs          AttendanceLog[]
  kudosSent               Kudos[]                  @relation("KudosFrom")
  kudosReceived           Kudos[]                  @relation("KudosTo")
  surveyResponses         SurveyResponse[]
  documentRequests        DocumentRequest[]
  messagesSent            Message[]                @relation("MsgFrom")
  messagesReceived        Message[]                @relation("MsgTo")
  billboardReads          BillboardRead[]
  billboardPosts          BillboardPost[]          @relation("PostAuthor")
  dayNotesAuthored        DayNote[]                @relation("NoteAuthor")
  documents               Document[]
  openShiftOffers         OpenShiftOffer[]
  predictabilityPayEvents PredictabilityPayEvent[]
  ewaWithdrawals          EwaWithdrawal[]
  incidentsReported       IncidentReport[]         @relation("IncidentReporter")
  incidentsReviewed       IncidentReport[]         @relation("IncidentReviewer")
  checkpointScans         CheckpointScan[]         @relation("CheckpointScanner")
  tipDistributions        TipDistribution[]        @relation("TipRecipient")
  customRoleAssignments   MemberRoleAssignment[]
  courseEnrollments       CourseEnrollment[]
  shiftBids               ShiftBid[]
  reviewsAsSubject        PerformanceReview[]      @relation("ReviewSubject")
  reviewsAsReviewer       PerformanceReview[]      @relation("ReviewReviewer")
  permits                 Permit[]
  checklistInstances      ChecklistInstance[]
  cashDrawerSessions      CashDrawerSession[]
  stationAssignments      StationAssignment[]
  onCallShifts            OnCallShift[]
  vehicleAssignments      VehicleAssignment[]
  jobCloseouts            JobCloseout[]
  departmentMemberships   DepartmentMembership[]
  laneAssignments         LaneAssignment[]
  shrinkEvents            ShrinkEvent[]
  vmTaskAssignments       VmTask[]            @relation("VmTaskAssignee")
  vmTaskSubmissions       VmTaskSubmission[]
  lpEventsReported        LossPreventionEvent[] @relation("LpReporter")
  hotDeskBookings         HotDeskBooking[]
  meetingRoomBookings     MeetingRoomBooking[]
  visitorHostings         Visitor[]           @relation("VisitorHost")
  classOccurrencesAsInstructor ClassOccurrence[] @relation("ClassInstructor")
  ptSessionsAsTrainer     PtSession[]         @relation("PtTrainer")

  @@index([organizationId, status])
  @@index([organizationId, locationId])
  @@index([locationId])
}

model Shift {
  id                      String   @id @default(uuid())
  locationId              String
  memberId                String?
  externalWorkerProfileId String? // set when shift is filled by a cross-org network worker
  startsAt                DateTime
  endsAt                  DateTime
  position                String?
  notes                   String?
  status                  String   @default("draft")
  isOpen                  Boolean  @default(false)
  createdAt               DateTime @default(now())

  // FIELD SERVICE: minimum skill tier required for this shift / job. The
  // marketplace ranker will skip members below this threshold.
  requiredSkillTier Int?

  // HEALTHCARE: unit the shift is staffing (drives patient-ratio checks)
  unit String?

  // GROCERY/RETAIL: department this shift is staffing (produce, deli, cashier, etc.)
  departmentId String?

  location                Location                 @relation(fields: [locationId], references: [id], onDelete: Cascade)
  member                  Member?                  @relation(fields: [memberId], references: [id])
  department              Department?              @relation(fields: [departmentId], references: [id])
  externalWorker          WorkerProfile?           @relation("ExternalWorker", fields: [externalWorkerProfileId], references: [id])
  tasks                   ShiftTask[]
  openRequests            OpenShiftRequest[]
  openShiftOffers         OpenShiftOffer[]
  swapRequests            ShiftSwapRequest[]
  predictabilityPayEvents PredictabilityPayEvent[]
  networkShiftOffers      NetworkShiftOffer[]
  incidentReports         IncidentReport[]
  checkpointScans         CheckpointScan[]
  bids                    ShiftBid[]
  checklistInstances      ChecklistInstance[]
  stationAssignments      StationAssignment[]
  vehicleAssignment       VehicleAssignment?
  jobCloseout             JobCloseout?
  laneAssignment          LaneAssignment?

  @@index([locationId, startsAt])
  @@index([memberId, startsAt])
  @@index([locationId, status, startsAt])
  @@index([isOpen, startsAt])
  @@index([departmentId, startsAt])
}

model ShiftTask {
  id      String  @id @default(uuid())
  shiftId String
  task    String
  done    Boolean @default(false)

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model OpenShiftRequest {
  id        String   @id @default(uuid())
  shiftId   String
  memberId  String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model OpenShiftOffer {
  id          String    @id @default(uuid())
  shiftId     String
  memberId    String
  wave        Int       @default(1)
  status      String    @default("pending") // pending | claimed | declined | expired | superseded
  sentAt      DateTime  @default(now())
  expiresAt   DateTime
  respondedAt DateTime?
  rationale   String?

  shift  Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([shiftId, memberId])
  @@index([memberId, status])
  @@index([shiftId, status])
}

model TimeOffRequest {
  id             String    @id @default(uuid())
  memberId       String
  startsOn       DateTime
  endsOn         DateTime
  reason         String?
  category       String    @default("vacation")
  status         String    @default("pending")
  hoursRequested Float? // computed at creation (business days × hours/day)
  hoursDeducted  Float? // set on approval (so we know exactly what to refund if reversed)
  createdAt      DateTime  @default(now())
  decidedAt      DateTime?
  decidedById    String?

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, status])
  @@index([memberId, startsOn])
  @@index([status, startsOn])
}

model ExpenseRequest {
  id        String   @id @default(uuid())
  memberId  String
  amount    Float
  currency  String   @default("USD")
  category  String?
  notes     String?
  status    String   @default("pending")
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, status])
  @@index([status, createdAt])
}

model Kudos {
  id        String   @id @default(uuid())
  fromId    String
  toId      String
  message   String
  emoji     String?
  createdAt DateTime @default(now())

  from Member @relation("KudosFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Member @relation("KudosTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([toId, createdAt])
  @@index([fromId, createdAt])
}

model PayPeriod {
  id             String   @id @default(uuid())
  organizationId String
  startsOn       DateTime
  endsOn         DateTime
  status         String   @default("open")

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries        TimesheetEntry[]
  ewaWithdrawals EwaWithdrawal[]

  @@index([organizationId, status])
  @@index([organizationId, startsOn])
}

model TimesheetEntry {
  id          String   @id @default(uuid())
  payPeriodId String
  memberId    String
  date        DateTime
  hours       Float
  approved    Boolean  @default(false)
  flagged     Boolean  @default(false)
  notes       String?

  payPeriod PayPeriod @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([payPeriodId, memberId])
  @@index([memberId, date])
  @@index([payPeriodId, approved])
}

model AttendanceLog {
  id             String   @id @default(uuid())
  memberId       String
  type           String
  at             DateTime @default(now())
  latitude       Float?
  longitude      Float?
  accuracyMeters Float?
  photoData      String? // base64 data URL (~50KB JPEG); for production swap to S3 URL
  locationId     String? // location they were assigned to at time of clock
  distanceMeters Float? // computed distance to assigned location
  withinGeofence Boolean? // null = unknown (no GPS), true/false = computed
  verified       Boolean  @default(false) // true if both GPS+photo were captured

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, at])
  @@index([at])
}

model Document {
  id             String   @id @default(uuid())
  organizationId String
  memberId       String?
  uploadedById   String?
  name           String
  url            String? // optional external link
  category       String?
  mimeType       String?
  sizeBytes      Int?
  data           Bytes? // for in-DB storage; production should use external blob storage
  uploadedAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member       Member?      @relation(fields: [memberId], references: [id])
}

model DocumentRequest {
  id           String   @id @default(uuid())
  memberId     String
  documentName String
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Survey {
  id             String   @id @default(uuid())
  organizationId String
  title          String
  description    String?
  status         String   @default("active")
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  questions    SurveyQuestion[]
  responses    SurveyResponse[]
}

model SurveyQuestion {
  id       String @id @default(uuid())
  surveyId String
  question String
  type     String @default("scale")
  order    Int    @default(0)

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model SurveyResponse {
  id          String   @id @default(uuid())
  surveyId    String
  memberId    String
  answers     String
  submittedAt DateTime @default(now())

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Message {
  id        String    @id @default(uuid())
  fromId    String
  toId      String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  from Member @relation("MsgFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Member @relation("MsgTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([toId, readAt, createdAt])
  @@index([fromId, createdAt])
  @@index([fromId, toId, createdAt])
}

model BillboardPost {
  id             String   @id @default(uuid())
  organizationId String
  authorId       String
  title          String
  body           String
  category       String?
  publishedAt    DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       Member          @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reads        BillboardRead[]

  @@index([organizationId, publishedAt])
}

model BillboardRead {
  id       String   @id @default(uuid())
  postId   String
  memberId String
  readAt   DateTime @default(now())

  post   BillboardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  member Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([postId, memberId])
}

model DayNote {
  id             String   @id @default(uuid())
  organizationId String
  locationId     String?
  date           DateTime
  body           String
  authorId       String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       Member       @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@index([locationId, date])
}

model HRReminder {
  id             String   @id @default(uuid())
  organizationId String
  title          String
  body           String?
  dueOn          DateTime
  done           Boolean  @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ============================================================================
// Schedule templates — save a named week pattern and re-apply later.
// Stronger version of "copy from last week" because the saved shape doesn't
// drift with whatever happened to be on the calendar last Monday.
// ============================================================================
model ScheduleTemplate {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  // Snapshot of shifts captured at save time. JSON-encoded array of:
  //   { dayOfWeek: 0-6, startTime: "HH:MM", endTime: "HH:MM",
  //     locationId, memberId | null (open shift), position }
  shifts         String // JSON
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, name])
}

// ============================================================================
// Outbound webhooks — customer-managed integrations. Customer creates a
// subscription pointing to their own endpoint; we POST signed events.
// Common events: shift.published, member.invited, timesheet.approved, etc.
// ============================================================================
model WebhookSubscription {
  id                  String    @id @default(uuid())
  organizationId      String
  url                 String
  secret              String // HMAC-SHA256 signing secret (shown ONCE on create)
  description         String?
  events              String // JSON array of subscribed event types
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  // Delivery health
  lastDeliveryAt      DateTime?
  lastDeliveryStatus  Int? // last HTTP status code
  consecutiveFailures Int       @default(0)
  disabledAt          DateTime? // auto-disabled after N consecutive failures

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([organizationId, active])
}

model WebhookDelivery {
  id             String    @id @default(uuid())
  subscriptionId String
  organizationId String
  eventType      String
  payload        String // JSON; the body we POSTed
  status         String // "pending" | "delivered" | "failed" | "skipped"
  httpStatus     Int?
  responseBody   String? // truncated to 1KB
  attempts       Int       @default(0)
  nextRetryAt    DateTime?
  createdAt      DateTime  @default(now())
  deliveredAt    DateTime?

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, status, nextRetryAt])
  @@index([organizationId, createdAt])
}

// ============================================================================
// SMS message log — outbound only. Lets managers audit what was sent and
// supports rate-limiting + abuse detection.
// ============================================================================
model SmsMessage {
  id             String    @id @default(uuid())
  organizationId String
  memberId       String? // null if sent to an external invitee
  toNumber       String
  body           String
  category       String // "shift_offer" | "schedule_change" | "time_off" | "alert" | "test"
  status         String    @default("queued") // queued | sent | failed
  twilioSid      String?   @unique
  errorMessage   String?
  createdAt      DateTime  @default(now())
  sentAt         DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([memberId, createdAt])
}

// ============================================================================
// OAuth identity link. Multiple providers per user (Google + Microsoft can be
// linked to the same account). Login flow checks here for an existing link
// and signs the user in if found.
// ============================================================================
model OAuthIdentity {
  id         String    @id @default(uuid())
  userId     String
  provider   String // "google" | "microsoft"
  providerId String // the provider's "sub" / object id
  email      String // email from the provider (for audit / debugging)
  linkedAt   DateTime  @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

// ============================================================================
// GDPR / CCPA data export requests. User clicks "export my data" → we build
// a JSON blob → return downloadable link. Tracks completion + expiry.
// ============================================================================
model DataExportRequest {
  id             String    @id @default(uuid())
  userId         String
  organizationId String?
  status         String    @default("pending") // pending | building | ready | failed | expired
  payload        String? // JSON blob
  sizeBytes      Int?
  errorMessage   String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  expiresAt      DateTime?

  @@index([userId, status])
}

// ============================================================================
// Custom roles + permissions. Per-org named roles that complement the three
// built-in roles. A member can opt into a custom role on top of their built-in
// role; permission checks union both.
// ============================================================================
model CustomRole {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  permissions    String // JSON array, e.g. ["schedule.write","timesheets.approve"]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      MemberRoleAssignment[]

  @@unique([organizationId, name])
}

model MemberRoleAssignment {
  id           String   @id @default(uuid())
  memberId     String
  customRoleId String
  assignedAt   DateTime @default(now())

  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  customRole CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)

  @@unique([memberId, customRoleId])
  @@index([memberId])
}

// ============================================================================
// Training & LMS. Org-level Course with ordered Lessons (text + optional
// embedded quiz). Members get a CourseEnrollment tracking progress.
// ============================================================================
model Course {
  id               String   @id @default(uuid())
  organizationId   String
  title            String
  description      String?
  category         String? // "onboarding" | "safety" | "compliance" | "skills" | "other"
  estimatedMinutes Int      @default(15)
  passingScore     Int      @default(80)
  published        Boolean  @default(true)
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lessons      Lesson[]
  enrollments  CourseEnrollment[]

  @@index([organizationId, published])
}

model Lesson {
  id        String   @id @default(uuid())
  courseId  String
  order     Int      @default(0)
  title     String
  body      String // markdown-ish text; supports embedded video / image URLs
  quizJson  String? // JSON: [{ question, choices[], correctIndex }]
  createdAt DateTime @default(now())

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([courseId, order])
}

model CourseEnrollment {
  id          String    @id @default(uuid())
  courseId    String
  memberId    String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  score       Int?

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  member   Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@unique([courseId, memberId])
  @@index([memberId, completedAt])
}

model LessonProgress {
  id           String    @id @default(uuid())
  enrollmentId String
  lessonId     String
  completedAt  DateTime?
  lastScore    Int?
  attempts     Int       @default(0)

  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
}

// ============================================================================
// Bid-based shift selection. Employees bid on open shifts (1 = top choice).
// Manager sees demand heatmap + uses bids when assigning.
// ============================================================================
model ShiftBid {
  id        String   @id @default(uuid())
  shiftId   String
  memberId  String
  priority  Int      @default(1) // 1 = top choice; higher = less preferred
  note      String?
  createdAt DateTime @default(now())

  shift  Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([shiftId, memberId])
  @@index([shiftId])
  @@index([memberId, createdAt])
}

// ============================================================================
// Performance reviews. ReviewCycle is an org-level review period; Review
// is the manager↔employee record inside that cycle (or peer/self).
// ============================================================================
model ReviewCycle {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  rubric         String? // JSON: [{ key, label, weight 0-1 }]
  status         String    @default("draft") // draft | active | closed
  opensAt        DateTime?
  closesAt       DateTime?
  createdAt      DateTime  @default(now())

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviews      PerformanceReview[]

  @@index([organizationId, status])
}

model PerformanceReview {
  id               String    @id @default(uuid())
  cycleId          String
  subjectMemberId  String
  reviewerMemberId String
  type             String    @default("manager") // manager | peer | self
  payload          String? // JSON { ratings: {key:1-5}, comment, strengths, growth }
  overallRating    Int? // 1-5
  submittedAt      DateTime?
  acknowledgedAt   DateTime?
  createdAt        DateTime  @default(now())

  cycle          ReviewCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  subjectMember  Member      @relation("ReviewSubject", fields: [subjectMemberId], references: [id], onDelete: Cascade)
  reviewerMember Member      @relation("ReviewReviewer", fields: [reviewerMemberId], references: [id], onDelete: Cascade)

  @@unique([cycleId, subjectMemberId, reviewerMemberId])
  @@index([subjectMemberId, submittedAt])
  @@index([reviewerMemberId, submittedAt])
}

// ============================================================================
// Permits & licences. Distinct from MemberCertification because:
//   - permits are MANDATORY for legal operation (block scheduling on expiry)
//   - they have escalating reminder cadences (60/30/14/7/0/expired)
//   - they track the actual renewal fee for budgeting
//   - they can be org-level (agency licence) OR member-level (per-guard licence)
//
// Pre-configured categories cover security, healthcare, food service, and
// transport — the most common regulated verticals. "custom" is the escape hatch.
// ============================================================================
model Permit {
  id             String  @id @default(uuid())
  organizationId String
  memberId       String? // null = agency-level (e.g. company licence, insurance bond)

  // Classification
  category    String // "agency_license" | "guard_license" | "firearm" | "food_handler" | "rn_license" | "lpn_license" | "cpr" | "osha_30" | "cdl" | "alcohol_service" | "custom"
  customLabel String? // when category="custom"

  // Issuer details
  regulator    String? // "Bureau de la sécurité privée (QC)", "California BSIS", etc.
  permitNumber String?

  // Dates
  issuedOn  DateTime?
  expiresOn DateTime

  // Money — annual fee for budgeting + reminders
  feeAmountCents Int?

  // Renewal helpers — direct link to the regulator's portal
  renewalUrl String?

  // Reminder bookkeeping — which reminders we've already fired, so the daily
  // cron doesn't spam the team.
  reminder60dSentAt     DateTime?
  reminder30dSentAt     DateTime?
  reminder14dSentAt     DateTime?
  reminder7dSentAt      DateTime?
  reminderDaySentAt     DateTime?
  reminderExpiredSentAt DateTime?

  // Auto-enforcement. When true and expiresOn < now, the member with this
  // permit is blocked from being scheduled to new shifts.
  blocksScheduling Boolean @default(true)

  // Attachments + notes
  fileUrl String?
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member       Member?      @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([organizationId, expiresOn])
  @@index([memberId, expiresOn])
  @@index([expiresOn, blocksScheduling])
}

// ============================================================================
// 86-list. Items the kitchen / bar runs out of mid-shift. When a manager
// 86's an item, every on-duty server gets a push + SMS so they stop pitching
// it. Items can be unmarked when restocked.
// ============================================================================
model EightySixItem {
  id             String    @id @default(uuid())
  organizationId String
  locationId     String
  name           String
  category       String? // "food" | "drink" | "wine" | "beer" | "cocktail" | "other"
  notes          String?
  // Lifecycle
  active         Boolean   @default(true)
  markedById     String? // member who 86'd it
  markedAt       DateTime  @default(now())
  unmarkedAt     DateTime?
  unmarkedById   String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, active, markedAt])
}

// ============================================================================
// Shift checklists. ChecklistTemplate is reusable (org-level definition);
// ChecklistInstance is per-shift (filled out by the employee). Photos prove
// the work was done. Required completion can block clock-out.
// ============================================================================
model ChecklistTemplate {
  id                String   @id @default(uuid())
  organizationId    String
  locationId        String? // null = applies to all locations in the org
  name              String // "Opening side work", "Closing kitchen"
  trigger           String   @default("post_shift") // "pre_shift" | "post_shift" | "manual"
  requireCompletion Boolean  @default(true)
  positions         String? // JSON array of position names; null = all positions
  items             String // JSON: [{ id, text, requiresPhoto, requiresNote }]
  active            Boolean  @default(true)
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?           @relation(fields: [locationId], references: [id])
  instances    ChecklistInstance[]

  @@index([organizationId, active])
  @@index([locationId, trigger])
}

model ChecklistInstance {
  id          String    @id @default(uuid())
  templateId  String
  shiftId     String?
  memberId    String
  locationId  String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  responses   String    @default("[]") // JSON: [{ itemId, done, completedAt, photoData?, note? }]

  template       ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  shift          Shift?            @relation(fields: [shiftId], references: [id])
  member         Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  location       Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  Organization   Organization?     @relation(fields: [organizationId], references: [id])
  organizationId String?

  @@index([memberId, completedAt])
  @@index([shiftId])
}

// ============================================================================
// Cash drawer reconciliation. Per-shift open + close counts with variance.
// ============================================================================
model CashDrawerSession {
  id              String    @id @default(uuid())
  organizationId  String
  locationId      String
  shiftId         String?
  memberId        String
  openedAt        DateTime  @default(now())
  openCountCents  Int
  closedAt        DateTime?
  closeCountCents Int?
  expectedCents   Int? // openCount + cash sales - cash refunds (from POS)
  varianceCents   Int? // closeCount - expectedCents
  varianceReason  String?
  notes           String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([locationId, openedAt])
  @@index([memberId, openedAt])
}

// ============================================================================
// Section / station assignment. Tracks who worked which section so the
// rotation algorithm can stay fair (don't always put the same server on the
// patio, don't always put the same line cook on grill).
// ============================================================================
model StationAssignment {
  id        String   @id @default(uuid())
  shiftId   String
  memberId  String
  station   String // free-form: "Patio", "Bar", "Tables 1-10", "Grill", "Window"
  createdAt DateTime @default(now())

  shift  Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([shiftId, memberId])
  @@index([memberId, createdAt])
  @@index([shiftId])
}

// ============================================================================
// Live labor% alert config. Per-location target labor% (labor cost / revenue
// × 100). Cron checks every 15 min during open hours and texts the manager
// if actuals breach target by more than the threshold.
// ============================================================================
model LaborTarget {
  id                     String    @id @default(uuid())
  organizationId         String
  locationId             String    @unique
  targetPercent          Float     @default(28.0)
  breachThreshold        Float     @default(3.0)
  alertManagerId         String? // memberId to text; null = all managers at location
  active                 Boolean   @default(true)
  cooldownMinutes        Int       @default(60)
  lastAlertAt            DateTime?
  lastAlertActualPercent Float?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([organizationId, active])
}

// ============================================================================
// HEALTHCARE: Patient-to-staff ratio rules. Org defines the legal ratio per
// (unit, role). When a shift is created or updated, we count concurrent
// staff on that unit during the shift's window and refuse if the ratio
// would be violated.
// ============================================================================
model PatientRatioRule {
  id             String   @id @default(uuid())
  organizationId String
  locationId     String?
  unit           String // "med_surg" | "icu" | "step_down" | "ed" | "psych" | "lt_care" | custom
  customLabel    String?
  role           String   @default("RN") // "RN" | "LPN" | "CNA"
  patientCount   Int // # patients covered
  staffCount     Int // # of <role> required for that patient load (typically 1)
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id])

  @@index([organizationId, active])
}

// ============================================================================
// Shift differential pay. Rules like "Sundays = 1.5x", "Nights 22:00-06:00 =
// 1.15x", "Holidays = 2x". The payroll calculator splits TimesheetEntry hours
// by hour-bucket and applies the highest matching rule per hour.
// ============================================================================
model ShiftDifferential {
  id             String   @id @default(uuid())
  organizationId String
  name           String // "Night shift", "Weekend", "Christmas"
  kind           String // "night" | "weekend" | "holiday" | "custom"
  startHour      Int? // 0-23 (for night/custom)
  endHour        Int? // 0-23 (for night/custom)
  dayOfWeek      Int? // 0-6 (for weekend/custom; 0=Sun)
  holidayDates   String? // JSON array of ISO dates "2026-12-25"
  multiplier     Float    @default(1.5) // 1.5 = time-and-a-half
  flatAddCents   Int? // optional flat $/hr on top
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, active])
}

// ============================================================================
// On-call rotation. Separate from regular shifts because pay rules differ
// (daily stipend + call-in premium) and fairness matters across the team.
// ============================================================================
model OnCallShift {
  id                        String   @id @default(uuid())
  organizationId            String
  locationId                String?
  memberId                  String
  startsAt                  DateTime
  endsAt                    DateTime
  stipendCents              Int      @default(0)
  calledInHours             Float?
  calledInPremiumMultiplier Float? // applied to base rate (e.g. 1.5)
  notes                     String?
  createdAt                 DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id])

  @@index([organizationId, startsAt])
  @@index([memberId, startsAt])
}

// ============================================================================
// FIELD SERVICE: Vehicles + fleet assets. Each shift can be assigned a
// vehicle. Pre-trip inspection runs against the existing checklist engine.
// ============================================================================
model Vehicle {
  id             String   @id @default(uuid())
  organizationId String
  locationId     String? // home base
  name           String
  licensePlate   String?
  vin            String?
  make           String?
  model          String?
  year           Int?
  status         String   @default("active") // active | maintenance | retired
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?           @relation(fields: [locationId], references: [id])
  assignments  VehicleAssignment[]

  @@index([organizationId, status])
}

model VehicleAssignment {
  id                         String   @id @default(uuid())
  shiftId                    String   @unique
  vehicleId                  String
  memberId                   String
  startMileage               Int?
  endMileage                 Int?
  preTripChecklistInstanceId String?
  createdAt                  DateTime @default(now())

  shift   Shift   @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([vehicleId, createdAt])
  @@index([memberId, createdAt])
}

// ============================================================================
// Job closeout. Customer signature (base64 PNG), photo evidence, completion
// notes, optional customer rating, parts cost for profitability math.
// ============================================================================
model JobCloseout {
  id             String   @id @default(uuid())
  organizationId String
  shiftId        String   @unique
  memberId       String
  customerName   String?
  customerEmail  String?
  signatureData  String? // base64 PNG of the scribble (~50KB)
  rating         Int? // 1-5
  notes          String?
  photoData      String? // base64 ~250KB
  partsCostCents Int?
  closedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shift        Shift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([organizationId, closedAt])
}

// ============================================================================
// GROCERY + RETAIL: Department zones. Stores partition staff & shifts by
// section (Produce, Deli, Bakery, Cashier, Apparel, etc.). Min staffing by
// hour-of-week lets the coverage center flag under-staffed zones.
// ============================================================================
model Department {
  id             String   @id @default(uuid())
  organizationId String
  locationId     String? // null = applies to all locations
  name           String
  color          String   @default("#6366f1") // hex for schedule chips
  // JSON: { "mon": { "0": 1, "1": 1, ... "23": 2 }, ... } — min staff per hour
  minStaffByHour String?
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?              @relation(fields: [locationId], references: [id])
  memberships  DepartmentMembership[]
  shifts       Shift[]

  @@index([organizationId, active])
  @@index([locationId])
}

model DepartmentMembership {
  id           String  @id @default(uuid())
  departmentId String
  memberId     String
  isPrimary    Boolean @default(false) // primary department for this member

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([departmentId, memberId])
  @@index([memberId])
}

// ============================================================================
// GROCERY: POS lane / register assignments. Front-end managers pre-assign
// cashiers to lanes during peak so the line never builds up.
// ============================================================================
model PosLane {
  id             String   @id @default(uuid())
  organizationId String
  locationId     String
  number         Int // lane #
  name           String? // e.g. "Express 10-items"
  type           String   @default("standard") // standard | express | self_checkout
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  assignments  LaneAssignment[]

  @@unique([locationId, number])
}

model LaneAssignment {
  id        String   @id @default(uuid())
  shiftId   String   @unique
  laneId    String
  memberId  String
  fromMin   Int? // minutes from shift start (null = full shift)
  toMin     Int?
  createdAt DateTime @default(now())

  shift  Shift   @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  lane   PosLane @relation(fields: [laneId], references: [id], onDelete: Cascade)
  member Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([laneId])
}

// ============================================================================
// GROCERY + RETAIL: Shrink (lost merchandise) tracking. Tied to the shift
// or department so loss-rate trends can be sliced by team.
// ============================================================================
model ShrinkEvent {
  id             String   @id @default(uuid())
  organizationId String
  locationId     String?
  departmentId   String?
  shiftId        String?
  reportedById   String? // member who reported
  reason         String // damage | spoilage | theft | expired | return | other
  productName    String
  sku            String?
  quantity       Float    @default(1)
  unitValueCents Int      @default(0)
  totalValueCents Int     @default(0)
  notes          String?
  occurredAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id])
  reportedBy   Member?      @relation(fields: [reportedById], references: [id])

  @@index([organizationId, occurredAt])
  @@index([locationId, occurredAt])
  @@index([reason])
}

// ============================================================================
// RETAIL: Visual merchandising tasks. Each task can require a photo proof
// (endcap built? window display set? floor reset?) — the engine tracks
// completion + before/after photos for the brand-compliance audit.
// ============================================================================
model VmTask {
  id                String   @id @default(uuid())
  organizationId    String
  locationId        String?
  name              String
  description       String?
  dueDate           DateTime?
  requirePhoto      Boolean  @default(true)
  assignedToMemberId String?
  status            String   @default("open") // open | done | overdue | cancelled
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?           @relation(fields: [locationId], references: [id])
  assignedTo   Member?             @relation("VmTaskAssignee", fields: [assignedToMemberId], references: [id])
  submissions  VmTaskSubmission[]

  @@index([organizationId, status])
  @@index([locationId])
}

model VmTaskSubmission {
  id          String   @id @default(uuid())
  vmTaskId    String
  memberId    String
  photoData   String? // base64 JPEG
  notes       String?
  submittedAt DateTime @default(now())

  task   VmTask @relation(fields: [vmTaskId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([vmTaskId])
}

// ============================================================================
// RETAIL: Loss prevention events (theft, errors, breakage). Lighter than the
// security IncidentReport (no police involvement, no full narrative). Used
// for trend reporting + per-employee follow-up.
// ============================================================================
model LossPreventionEvent {
  id             String   @id @default(uuid())
  organizationId String
  locationId     String?
  type           String // shoplift | register_error | breakage | refund_fraud | sweethearting | other
  valueCents     Int?
  description    String
  reportedById   String?
  occurredAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id])
  reportedBy   Member?      @relation("LpReporter", fields: [reportedById], references: [id])

  @@index([organizationId, occurredAt])
  @@index([type])
}

// ============================================================================
// OFFICE: Hot-desking / hoteling. Hybrid teams book a desk for the day.
// Half-day bookings (AM/PM/full) supported.
// ============================================================================
model HotDesk {
  id             String   @id @default(uuid())
  organizationId String
  locationId     String?
  name           String // "Desk 14"
  zone           String? // "Engineering", "Sales floor"
  hasMonitor     Boolean  @default(false)
  hasStanding    Boolean  @default(false)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?        @relation(fields: [locationId], references: [id])
  bookings     HotDeskBooking[]

  @@index([organizationId, active])
}

model HotDeskBooking {
  id        String   @id @default(uuid())
  hotDeskId String
  memberId  String
  date      DateTime // date portion only (compared as day)
  halfDay   String   @default("full") // am | pm | full
  createdAt DateTime @default(now())

  hotDesk HotDesk @relation(fields: [hotDeskId], references: [id], onDelete: Cascade)
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([hotDeskId, date, halfDay])
  @@index([memberId, date])
}

// ============================================================================
// OFFICE: Meeting rooms + bookings.
// ============================================================================
model MeetingRoom {
  id             String   @id @default(uuid())
  organizationId String
  locationId     String?
  name           String
  capacity       Int      @default(4)
  hasVideo       Boolean  @default(true)
  hasWhiteboard  Boolean  @default(false)
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?            @relation(fields: [locationId], references: [id])
  bookings     MeetingRoomBooking[]

  @@index([organizationId, active])
}

model MeetingRoomBooking {
  id            String   @id @default(uuid())
  meetingRoomId String
  organizerId   String
  startsAt      DateTime
  endsAt        DateTime
  title         String
  attendees     String? // JSON array of names
  createdAt     DateTime @default(now())

  room      MeetingRoom @relation(fields: [meetingRoomId], references: [id], onDelete: Cascade)
  organizer Member      @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([meetingRoomId, startsAt])
  @@index([organizerId, startsAt])
}

// ============================================================================
// OFFICE: Visitor log. Front-desk signs guests in, hosts get notified,
// badge numbers tracked for evacuation lists.
// ============================================================================
model Visitor {
  id             String    @id @default(uuid())
  organizationId String
  locationId     String?
  name           String
  company        String?
  hostMemberId   String
  badgeNumber    String?
  purpose        String? // "Meeting", "Interview", "Delivery"
  checkedInAt    DateTime  @default(now())
  checkedOutAt   DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id])
  host         Member       @relation("VisitorHost", fields: [hostMemberId], references: [id], onDelete: Cascade)

  @@index([organizationId, checkedInAt])
  @@index([hostMemberId])
}

// ============================================================================
// FITNESS: Group fitness classes + per-occurrence instructor assignment.
// Schedule a recurring template, expand into individual ClassOccurrences,
// each with its own instructor and (optional) room.
// ============================================================================
model FitnessClass {
  id             String   @id @default(uuid())
  organizationId String
  locationId     String?
  name           String
  durationMins  Int      @default(60)
  capacity       Int      @default(20)
  color          String   @default("#10b981")
  description    String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?         @relation(fields: [locationId], references: [id])
  occurrences  ClassOccurrence[]

  @@index([organizationId, active])
}

model ClassOccurrence {
  id                  String   @id @default(uuid())
  fitnessClassId      String
  instructorMemberId  String
  startsAt            DateTime
  endsAt              DateTime
  room                String?
  status              String   @default("scheduled") // scheduled | done | cancelled
  attendees           Int      @default(0)
  notes               String?
  createdAt           DateTime @default(now())

  fitnessClass FitnessClass @relation(fields: [fitnessClassId], references: [id], onDelete: Cascade)
  instructor   Member       @relation("ClassInstructor", fields: [instructorMemberId], references: [id])

  @@index([fitnessClassId, startsAt])
  @@index([instructorMemberId, startsAt])
}

// ============================================================================
// FITNESS: Personal-training sessions. Booking-driven, paid per session,
// trainer keeps their own client list.
// ============================================================================
model PtSession {
  id              String   @id @default(uuid())
  organizationId  String
  trainerMemberId String
  clientName      String
  clientPhone     String?
  startsAt        DateTime
  endsAt          DateTime
  status          String   @default("booked") // booked | done | no_show | cancelled
  rateCents       Int      @default(0)
  trainerSplitPct Int      @default(70) // % of revenue paid to trainer
  notes           String?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trainer      Member       @relation("PtTrainer", fields: [trainerMemberId], references: [id], onDelete: Cascade)

  @@index([organizationId, startsAt])
  @@index([trainerMemberId, startsAt])
}
