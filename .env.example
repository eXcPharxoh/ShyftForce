# ───────────────────────────────────────────────
# Required
# ───────────────────────────────────────────────
# Postgres connection. Get yours free at https://neon.tech (recommended) or any Postgres host.
# PROD on Neon: DATABASE_URL = the POOLED endpoint (host contains "-pooler"), e.g.
#   postgresql://USER:PW@ep-xxx-pooler.REGION.aws.neon.tech/db?sslmode=require&pgbouncer=true&connection_limit=1
# DIRECT_URL = the DIRECT (non-pooled) endpoint — used only by `prisma migrate`.
# In local dev both can be the same direct connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
NEXTAUTH_URL="http://localhost:3210"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ───────────────────────────────────────────────
# Three-subdomain production deployment (recommended)
# Marketing on root, customer app + platform admin on subdomains.
# All three point at the SAME Vercel project; src/middleware.ts routes by host.
# Leave blank in dev — middleware no-ops on localhost.
# ───────────────────────────────────────────────
NEXT_PUBLIC_MARKETING_HOST="shyftforce.com"
NEXT_PUBLIC_APP_HOST="app.shyftforce.com"
NEXT_PUBLIC_ADMIN_HOST="admin.shyftforce.com"
# Share session cookies across subdomains in production. Leave blank in dev.
# Lead with a dot so all subdomains inherit it.
NEXTAUTH_COOKIE_DOMAIN=".shyftforce.com"

# ───────────────────────────────────────────────
# AI features (Co-pilot + Auto-Scheduler)
# Get a key at https://console.anthropic.com/
# ───────────────────────────────────────────────
SHYFTFORCE_AI_KEY=""

# ───────────────────────────────────────────────
# Email (Resend) — leave blank in dev to log to console
# Get a key at https://resend.com
# ───────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="shyftforce <noreply@yourdomain.com>"

# ───────────────────────────────────────────────
# Stripe billing — leave blank to disable billing flows
# Get keys at https://dashboard.stripe.com/apikeys
# ───────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Two prices per paid plan:
#   _BASE = the flat monthly base ($29 Pro / $79 Business)
#   _SEAT = per-seat overage above included seats ($4 Pro / $6 Business),
#          billed as a quantity-based subscription item.
# In Stripe dashboard: Products → New product → add TWO prices (Recurring monthly
# for base, Recurring monthly "per unit" for seat). Copy the price IDs here.
STRIPE_PRICE_PRO_BASE=""
STRIPE_PRICE_PRO_SEAT=""
STRIPE_PRICE_BUSINESS_BASE=""
STRIPE_PRICE_BUSINESS_SEAT=""
# Legacy single-line fallback (only used if PRO_BASE not set)
STRIPE_PRICE_PRO=""

# ───────────────────────────────────────────────
# Finch (payroll integration: ADP, Gusto, Paychex, Rippling, QuickBooks…)
# Sign up at https://dashboard.tryfinch.com — sandbox is free
# ───────────────────────────────────────────────
FINCH_CLIENT_ID=""
FINCH_CLIENT_SECRET=""
FINCH_REDIRECT_URI=""           # e.g. https://yourdomain.com/api/finch/callback
FINCH_USE_SANDBOX="true"        # "true" for testing, "false" for production

# ───────────────────────────────────────────────
# Twilio SMS — outbound shift offers, schedule changes, time-off decisions
# Sign up at https://www.twilio.com/console
# This is the PLATFORM fallback. Customers can bring their own Twilio via
# org settings (Org.twilioAccountSid/AuthToken/FromNumber) and it overrides.
# Leave all three blank in dev → SMS sends go to console.log.
# ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""           # E.164 format, e.g. "+15551234567"

# ───────────────────────────────────────────────
# Web Push (VAPID) — server-pushes notifications to PWAs
# Generate keypair once with `npx web-push generate-vapid-keys`.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY ships to browsers; PRIVATE stays server-side.
# Leave blank → web push disabled (SMS still works).
# ───────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:noreply@shyftforce.com"

# ───────────────────────────────────────────────
# Slack OAuth — connect to a Slack workspace for in-channel notifications
# Create app at https://api.slack.com/apps with bot scopes:
#   chat:write, chat:write.public, channels:read, groups:read, team:read
# ───────────────────────────────────────────────
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_REDIRECT_URI=""           # e.g. https://app.shyftforce.com/api/slack/callback

# ───────────────────────────────────────────────
# OAuth SSO — sign in with Google / Microsoft
# Configure in respective dev consoles. NEXT_PUBLIC_*_LOGIN="1" reveals the
# button on the login page; the server validates credentials regardless.
# ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_LOGIN=""

AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"     # "common" = any AAD tenant + personal Microsoft accounts
NEXT_PUBLIC_MICROSOFT_LOGIN=""

# ───────────────────────────────────────────────
# Cron secret (Self-Healing Schedule + POS sync + Reputation)
# Vercel cron auto-injects this as Bearer token. Generate with:
#   openssl rand -hex 24
# Required if you want the autopilot loops to advance unattended.
# ───────────────────────────────────────────────
CRON_SECRET=""

# ───────────────────────────────────────────────
# Platform admin — comma-separated emails that get /platform access
# These users can see every org, every user, audit logs, and impersonate
# any user for support. AUDIT LOGGED to AuditLog on every impersonation.
# Leave blank to disable platform admin entirely (recommended in prod
# unless you specifically need cross-org diagnostics).
# ───────────────────────────────────────────────
PLATFORM_ADMIN_EMAILS=""    # e.g. "you@company.com,cofounder@company.com"

# ───────────────────────────────────────────────
# POS integrations (Live Labor Cost)
# Toast: https://doc.toasttab.com/   Square: https://developer.squareup.com/
# Leave blank for manual revenue entry — works without external keys.
# ───────────────────────────────────────────────
TOAST_API_BASE="https://ws-api.toasttab.com"
TOAST_CLIENT_ID=""
TOAST_CLIENT_SECRET=""
SQUARE_API_BASE="https://connect.squareup.com"
SQUARE_CLIENT_ID=""
SQUARE_CLIENT_SECRET=""
